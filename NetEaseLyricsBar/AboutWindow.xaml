<Window x:Class="NetEaseLyricsBar.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="关于"
        Width="540" Height="480"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Auto"
        FontFamily="Segoe UI"
        FontSize="14">

    <Window.Resources>
        <!-- Fluent UI 颜色 -->
        <SolidColorBrush x:Key="Fluent.Background" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="Fluent.CardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="Fluent.TextPrimary" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="Fluent.TextSecondary" Color="#616161"/>
        <SolidColorBrush x:Key="Fluent.Border" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="Fluent.Accent" Color="#0078D4"/>
        <SolidColorBrush x:Key="Fluent.AccentHover" Color="#106EBE"/>
        <SolidColorBrush x:Key="Fluent.Hover" Color="#F3F3F3"/>
    </Window.Resources>

    <!-- 亚克力效果背景 -->
    <Border Background="#F9F9F9"
            CornerRadius="8"
            BorderBrush="#E5E5E5"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="32" Opacity="0.14" Direction="270" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 - Fluent 风格 -->
            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#E5E5E5"
                    BorderThickness="0,0,0,1"
                    Padding="24,16,24,16">
                <Grid>
                    <TextBlock Text="关于"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Fluent.TextPrimary}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="CloseButton"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="32"
                            Height="32"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#616161"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    Width="{TemplateBinding Width}"
                                                    Height="{TemplateBinding Height}"
                                                    CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" TargetName="Border" Value="#F3F3F3"/>
                                                    <Setter Property="Foreground" Value="#1A1A1A"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" TargetName="Border" Value="#E5E5E5"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- 内容区 -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="32,24,32,24">
                <StackPanel>
                    <!-- 应用标题 -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                        <TextBlock Text="网易云音乐歌词栏"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource Fluent.TextPrimary}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="版本 1.0.0"
                                   FontSize="13"
                                   Foreground="{StaticResource Fluent.TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 信息卡片 -->
                    <Border Background="#FFFFFF"
                            CornerRadius="4"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1"
                            Padding="20"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <!-- 技术栈 -->
                            <TextBlock Text="技术"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Fluent.TextSecondary}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="C# / WPF / .NET 10.0"
                                       FontSize="14"
                                       Foreground="{StaticResource Fluent.TextPrimary}"
                                       Margin="0,0,0,20"/>

                            <!-- 功能特点 -->
                            <TextBlock Text="功能"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Fluent.TextSecondary}"
                                       Margin="0,0,0,8"/>
                            <StackPanel>
                                <TextBlock Text="• 透明无边框窗口"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 窗口拖动和位置记忆"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 三种歌词动画效果"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• Maple Mono 字体（16种字重/斜体）"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 系统托盘支持"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• 锁定位置功能"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="• Fluent UI 设计风格"
                                           FontSize="14"
                                           Foreground="{StaticResource Fluent.TextPrimary}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 快捷键卡片 -->
                    <Border Background="#FFFFFF"
                            CornerRadius="4"
                            BorderBrush="#E5E5E5"
                            BorderThickness="1"
                            Padding="20">
                        <StackPanel>
                            <TextBlock Text="快捷键"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource Fluent.TextSecondary}"
                                       Margin="0,0,0,12"/>

                            <!-- 快捷键列表 -->
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="#F3F3F3"
                                            BorderBrush="#E5E5E5"
                                            BorderThickness="1"
                                            Padding="10,6"
                                            CornerRadius="3"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="←  →"
                                                   FontSize="12"
                                                   Foreground="#1A1A1A"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="切换歌词"
                                               FontSize="14"
                                               Foreground="{StaticResource Fluent.TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="#F3F3F3"
                                            BorderBrush="#E5E5E5"
                                            BorderThickness="1"
                                            Padding="10,6"
                                            CornerRadius="3"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="空格"
                                                   FontSize="12"
                                                   Foreground="#1A1A1A"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="切换动画"
                                               FontSize="14"
                                               Foreground="{StaticResource Fluent.TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="#F3F3F3"
                                            BorderBrush="#E5E5E5"
                                            BorderThickness="1"
                                            Padding="10,6"
                                            CornerRadius="3"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="Ctrl+Alt+R"
                                                   FontSize="12"
                                                   Foreground="#1A1A1A"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="重置位置"
                                               FontSize="14"
                                               Foreground="{StaticResource Fluent.TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="#F3F3F3"
                                            BorderBrush="#E5E5E5"
                                            BorderThickness="1"
                                            Padding="10,6"
                                            CornerRadius="3"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="右键"
                                                   FontSize="12"
                                                   Foreground="#1A1A1A"
                                                   FontWeight="Medium"/>
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="打开菜单"
                                               FontSize="14"
                                               Foreground="{StaticResource Fluent.TextPrimary}"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2"
                    Background="#FFFFFF"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#E5E5E5"
                    BorderThickness="0,1,0,0"
                    Padding="24,16">
                <Button Content="确定"
                        HorizontalAlignment="Right"
                        MinWidth="100"
                        Padding="20,10"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#0078D4"/>
                            <Setter Property="Foreground" Value="#FFFFFF"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}"
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" TargetName="Border" Value="#106EBE"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" TargetName="Border" Value="#005A9E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Border>
</Window>
