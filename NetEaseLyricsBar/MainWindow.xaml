<Window x:Class="NetEaseLyricsBar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetEaseLyricsBar"
        xmlns:notify="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        mc:Ignorable="d"
        Title="网易云音乐歌词栏"
        Width="600" Height="40"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="Manual"
        FontFamily="Microsoft YaHei UI">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/MaterialDesign3.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 右键菜单 - Material Design 3 风格 -->
            <ContextMenu x:Key="LyricsContextMenu" Style="{StaticResource MD3.ContextMenu}">
                <MenuItem Header="🔓 锁定位置" Click="LockMenuItem_Click"/>
                <Separator Style="{StaticResource MD3.Separator}"/>
                <MenuItem Header="↺ 重置位置" Click="ResetPositionMenuItem_Click"/>
                <Separator Style="{StaticResource MD3.Separator}"/>
                <MenuItem Header="ℹ 关于" Click="AboutMenuItem_Click"/>
                <MenuItem Header="✕ 退出" Click="ExitMenuItem_Click"/>
            </ContextMenu>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <!-- 系统托盘图标 -->
        <notify:TaskbarIcon
            x:Name="NotifyIcon"
            IconSource="/NetEaseLyricsBar;component/trayicon.jpg"
            ToolTipText="网易云音乐歌词栏"
            Visibility="Visible"
            TrayMouseDoubleClick="NotifyIcon_TrayMouseDoubleClick"
            DockPanel.Dock="Top">
            <!-- 右键菜单 -->
            <notify:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示窗口" Click="ShowWindowMenuItem_Click"/>
                    <MenuItem Header="隐藏窗口" Click="HideWindowMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </notify:TaskbarIcon.ContextMenu>
        </notify:TaskbarIcon>

        <!-- 主界面 -->
        <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown" DockPanel.Dock="Top">
        <!-- 歌词容器 - 更透明的毛玻璃效果 -->
        <Border x:Name="LyricsContainer"
                Background="#B4000000"
                CornerRadius="12"
                Padding="20,8"
                Margin="4"
                ContextMenu="{StaticResource LyricsContextMenu}"
                MouseLeftButtonDown="LyricsContainer_MouseLeftButtonDown">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" Opacity="0.3" Direction="270" ShadowDepth="3"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：当前歌词（主歌词，大字） -->
                <TextBlock x:Name="LyricsText"
                           Grid.Column="0"
                           Text="{Binding CurrentLyrics.Text}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#FAFAFA"
                           TextAlignment="Left"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"/>

                <!-- 中间：歌手信息（小字，居中） -->
                <TextBlock x:Name="LyricsInfo"
                           Grid.Column="1"
                           Text="{Binding CurrentLyrics.Artist}"
                           FontSize="9"
                           Foreground="#E0E0E0"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Normal"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"/>

                <!-- 右侧：下一句歌词（次要，小字） -->
                <TextBlock x:Name="NextLyricsText"
                           Grid.Column="2"
                           Text="{Binding CurrentLyrics.NextText}"
                           FontSize="12"
                           FontWeight="Normal"
                           Foreground="#B0B0B0"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           Opacity="0.7"
                           TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>
        </Grid>
    </DockPanel>
</Window>
